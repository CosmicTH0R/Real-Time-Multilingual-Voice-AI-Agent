# ============================================
# Real-Time Multilingual Voice AI Agent
# Environment Configuration
# ============================================

# --- LLM Providers ---
# Primary: OpenAI GPT-4o
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Fallback: Google Gemini (free tier)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# LLM provider selection: "openai" or "gemini"
LLM_PROVIDER=gemini

# --- Speech-to-Text ---
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# --- Text-to-Speech ---
GOOGLE_TTS_API_KEY=your_google_tts_api_key_here
# Alternative: ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
TTS_PROVIDER=google

# --- Database ---
POSTGRES_USER=voiceai
POSTGRES_PASSWORD=voiceai_secret
POSTGRES_DB=voiceai_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://voiceai:voiceai_secret@postgres:5432/voiceai_db

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- Application ---
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
MOCK_MODE=true

# --- Latency ---
TARGET_LATENCY_MS=450

# --- Session ---
SESSION_TTL_SECONDS=1800
